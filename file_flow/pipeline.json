{
  "__说明": "本文件均在 file_flow 目录内维护。在仓库根执行: python -m file_flow.pipeline_merge 。相对路径先相对 cwd 已存在路径，否则相对 file_flow/。未写 file_flow_auto_batch 时默认 true（批量跑 out 目录下全部案件）。",

  "file_flow_steps": ["pdf_prepare", "llm_fill", "standards_review", "render_html"],
  "file_flow_auto_batch": true,

  "file_flow_pdf_dir": "pdfs",
  "file_flow_schema_json": "out/schema_example.json",
  "file_flow_standards_json": "out/standards_example.json",
  "file_flow_out_dir": "out",

  "file_flow_suffix_work": "_work",
  "file_flow_suffix_answered": "_answered",
  "file_flow_suffix_review": "_review",

  "file_flow_llm_extract": false,

  "__OpenDataLoader": "全文抽取与 Hybrid；按需改 hybrid_url。",

  "backend": "opendataloader",
  "hybrid": "docling-fast",
  "hybrid_url": "http://127.0.0.1:5002",
  "hybrid_mode": "full",
  "hybrid_timeout": "0",
  "hybrid_fallback": true,
  "hybrid_health_timeout_sec": 15.0,
  "skip_health_check": false,
  "hybrid_force_ocr": true,
  "hybrid_ocr_lang": "ch_sim,en",
  "table_method": "cluster",
  "reading_order": "xycut",
  "quiet": false,
  "markdown_by_page": true
}
